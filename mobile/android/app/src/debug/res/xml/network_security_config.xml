<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
      DEBUG ONLY:
      Allow cleartext traffic to any host so physical devices can hit a LAN dev server
      (e.g. http://192.168.x.x:4000) without having to keep updating allowlists.
    -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
