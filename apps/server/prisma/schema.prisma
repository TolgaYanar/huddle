generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(cuid())
  username     String      @unique
  passwordHash String
  createdAt    DateTime    @default(now())

  sessions   Session[]
  savedRooms SavedRoom[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model SavedRoom {
  id        String   @id @default(cuid())
  userId    String
  roomId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roomId])
  @@index([userId, createdAt])
}

model RoomMessage {
  id        String   @id @default(cuid())
  roomId    String
  senderId  String
  senderUsername String?
  text      String
  createdAt DateTime @default(now())

  @@index([roomId, createdAt])
}

model RoomActivity {
  id        String   @id @default(cuid())
  roomId    String
  kind      String
  action    String?
  timestamp Float?
  videoUrl  String?
  senderId  String?
  senderUsername String?
  createdAt DateTime @default(now())

  @@index([roomId, createdAt])
}

model RoomPlaylist {
  id               String   @id @default(cuid())
  roomId           String
  name             String
  description      String?
  createdBy        String
  createdByUsername String?
  isDefault        Boolean  @default(false)
  loop             Boolean  @default(false)
  shuffle          Boolean  @default(false)
  autoPlay         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  items RoomPlaylistItem[]

  @@index([roomId, createdAt])
}

model RoomPlaylistItem {
  id              String   @id @default(cuid())
  playlistId      String
  videoUrl        String
  title           String
  duration        Float?
  thumbnail       String?
  addedBy         String
  addedByUsername String?
  position        Int      @default(0)
  addedAt         DateTime @default(now())

  playlist RoomPlaylist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@index([playlistId, position])
}
