# Database Configuration
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Example: postgresql://postgres:password@localhost:5432/huddle?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/huddle?schema=public"

# YouTube Data API v3 Key
# Get your API key from: https://console.cloud.google.com/apis/credentials
# Enable YouTube Data API v3 for your project
YOUTUBE_API_KEY="YOUR_YOUTUBE_API_KEY_HERE"

# Optional: Server Port (defaults to 4000)
# PORT=4000
# CORS Origins (comma-separated list of allowed origins)
# For production: CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# For development: CORS_ORIGINS=http://localhost:3002
# Leave empty to allow all origins (not recommended for production)
CORS_ORIGINS="http://localhost:3002"

# Node Environment
NODE_ENV="development"